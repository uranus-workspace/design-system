    "fumadocs-ui": "^15.8.5",
    "lucide-react": "^0.469.0",
    "motion": "^11.15.0",
    "next": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/mdx": "^2.0.13",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "@uranus-workspace/biome-config": "workspace:*",
