{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "extends": ["@uranus-workspace/biome-config"],
  "files": {
    "ignore": [
      "**/node_modules",
      "**/dist",
      "**/.next",
      "**/.turbo",
      "**/storybook-static",
      "**/coverage",
      "**/.source",
      "pnpm-lock.yaml"
    ]
  },
  "overrides": [
    {
      "include": ["apps/docs/registry/ai/**", "packages/ai/**"],
      "linter": {
        "rules": {
          "a11y": {
            "useValidAriaRole": "off"
          }
        }
      }
    }
  ]
}
