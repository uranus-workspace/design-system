{
  "name": "@uranus-workspace/ai",
  "version": "0.0.1",
  "description": "Uranus Technologies AI components — chat, composer, streaming, audio, attachments, reasoning and planning surfaces built on @uranus-workspace/design-system and the Vercel AI SDK.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/uranus-workspace/design-system.git",
    "directory": "packages/ai"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "src", "CHANGELOG.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo coverage"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.469.0",
    "tailwind-merge": "^2.5.5"
  },
  "peerDependencies": {
    "@ai-sdk/react": "^2.0.0",
    "@uranus-workspace/design-system": "workspace:*",
    "ai": "^5.0.0",
    "motion": "^11.15.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.0",
    "remark-gfm": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "react-markdown": {
      "optional": true
    },
    "remark-gfm": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ai-sdk/react": "^2.0.0",
    "@storybook/react": "^8.4.7",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest-axe": "^3.5.9",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "@uranus-workspace/biome-config": "workspace:*",
    "@uranus-workspace/design-system": "workspace:*",
    "@uranus-workspace/test-config": "workspace:*",
    "@uranus-workspace/tsconfig": "workspace:*",
    "ai": "^5.0.0",
    "jest-axe": "^9.0.0",
    "jsdom": "^25.0.1",
    "motion": "^11.15.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
